# FCR-x402 Facilitator Configuration

# Server
PORT=3402
HOST=0.0.0.0

# Redis (recommended for production — in-memory fallback used if disabled)
# When running via docker-compose, set REDIS_HOST=redis (the service name)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=fcr-x402:
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=1000

# Lotus Node (Filecoin Calibration public RPC)
LOTUS_ENDPOINT=https://api.calibration.node.glif.io/rpc/v1
LOTUS_TOKEN=

# USDFC Token on Calibration
TOKEN_ADDRESS=0xb3042734b608a1B16e9e86B374A3f3e389B4cDf0
TOKEN_DECIMALS=18
TOKEN_NAME=USD for Filecoin Community

# Chain (314159 for Calibration, 314 for Mainnet)
CHAIN_ID=314159
CHAIN_NAME=calibration

# Risk Limits (in USD)
RISK_MAX_PER_TX=100
RISK_MAX_PENDING=50
RISK_DAILY_LIMIT=500

# Settlement
SETTLEMENT_MAX_ATTEMPTS=3
SETTLEMENT_RETRY_DELAY_MS=5000
SETTLEMENT_TIMEOUT_MS=300000

# FCR (Fast Confirmation Rule)
FCR_ENABLED=true
FCR_POLL_INTERVAL_MS=1000
FCR_MIN_TIME_IN_PREPARE_MS=5000

# Facilitator Wallet (for submitting transactions — needs tFIL for gas)
FACILITATOR_PRIVATE_KEY=your-private-key-here
FACILITATOR_ADDRESS=your-0x-address-here

# Stage 3: Bond + Deferred Contracts (optional — leave blank to disable)
# Deploy your own via: cd contracts && npx hardhat run scripts/deploy.ts --network calibration
BOND_CONTRACT_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
